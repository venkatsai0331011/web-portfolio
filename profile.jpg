/* ═══════════════════════════════════════════
   VARIABLES & RESET
═══════════════════════════════════════════ */
:root {
  --bg:        #080c14;
  --bg2:       #0d1220;
  --bg3:       #111827;
  --accent:    #00d4ff;
  --accent2:   #7c3aed;
  --accent3:   #06ffa5;
  --text:      #e8edf5;
  --text-dim:  #7a8499;
  --border:    rgba(0, 212, 255, 0.12);
  --card-bg:   rgba(13, 18, 32, 0.85);
  --glow:      0 0 30px rgba(0, 212, 255, 0.15);
  --font-head: 'Syne', sans-serif;
  --font-mono: 'DM Mono', monospace;
  --font-body: 'Outfit', sans-serif;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

html { scroll-behavior: smooth; font-size: 16px; }

body {
  background: var(--bg);
  color: var(--text);
  font-family: var(--font-body);
  overflow-x: hidden;
  line-height: 1.7;
}

a { text-decoration: none; color: inherit; }
ul { list-style: none; }
img { max-width: 100%; display: block; }

.container {
  max-width: 1100px;
  margin: 0 auto;
  padding: 0 2rem;
}

.accent { color: var(--accent); }

/* ═══════════════════════════════════════════
   NAVBAR
═══════════════════════════════════════════ */
#navbar {
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 1rem 3rem;
  background: rgba(8, 12, 20, 0.8);
  backdrop-filter: blur(16px);
  border-bottom: 1px solid var(--border);
  transition: padding 0.3s;
}

#navbar.scrolled { padding: 0.6rem 3rem; }

.nav-logo {
  font-family: var(--font-head);
  font-weight: 800;
  font-size: 1.35rem;
  letter-spacing: 0.05em;
}

.logo-bracket { color: var(--accent); }

.nav-links {
  display: flex;
  gap: 2.5rem;
}

.nav-links a {
  font-family: var(--font-mono);
  font-size: 0.82rem;
  color: var(--text-dim);
  letter-spacing: 0.06em;
  text-transform: lowercase;
  transition: color 0.2s;
  position: relative;
}

.nav-links a::after {
  content: '';
  position: absolute;
  bottom: -4px; left: 0;
  width: 0; height: 1px;
  background: var(--accent);
  transition: width 0.3s;
}

.nav-links a:hover { color: var(--accent); }
.nav-links a:hover::after { width: 100%; }

.hamburger {
  display: none;
  flex-direction: column;
  gap: 5px;
  background: none;
  border: none;
  cursor: pointer;
  padding: 4px;
}

.hamburger span {
  display: block;
  width: 24px; height: 2px;
  background: var(--text);
  transition: 0.3s;
}

.mobile-menu {
  display: none;
  position: fixed;
  top: 60px; left: 0; right: 0;
  background: var(--bg2);
  border-bottom: 1px solid var(--border);
  z-index: 998;
  padding: 1.5rem;
}

.mobile-menu ul { display: flex; flex-direction: column; gap: 1rem; }

.mobile-menu a {
  font-family: var(--font-mono);
  color: var(--text-dim);
  font-size: 0.9rem;
}

.mobile-menu a:hover { color: var(--accent); }

/* ═══════════════════════════════════════════
   HERO
═══════════════════════════════════════════ */
#hero {
  min-height: 100vh;
  display: flex;
  align-items: center;
  position: relative;
  overflow: hidden;
  padding: 7rem 3rem 4rem;
}

.hero-bg-grid {
  position: absolute;
  inset: 0;
  background-image:
    linear-gradient(rgba(0,212,255,0.04) 1px, transparent 1px),
    linear-gradient(90deg, rgba(0,212,255,0.04) 1px, transparent 1px);
  background-size: 50px 50px;
  pointer-events: none;
}

.hero-orb {
  position: absolute;
  border-radius: 50%;
  filter: blur(80px);
  pointer-events: none;
}

.hero-orb-1 {
  width: 500px; height: 500px;
  background: radial-gradient(circle, rgba(0,212,255,0.12), transparent 70%);
  top: -100px; left: -100px;
}

.hero-orb-2 {
  width: 400px; height: 400px;
  background: radial-gradient(circle, rgba(124,58,237,0.15), transparent 70%);
  bottom: -50px; right: -50px;
}

.hero-content {
  max-width: 1100px;
  margin: 0 auto;
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 3rem;
}

.hero-text { flex: 1; }

.hero-greeting {
  font-family: var(--font-mono);
  color: var(--text-dim);
  font-size: 1rem;
  margin-bottom: 0.5rem;
  letter-spacing: 0.05em;
}

.hero-name {
  font-family: var(--font-head);
  font-size: clamp(2.4rem, 5vw, 3.8rem);
  font-weight: 800;
  color: var(--accent);
  line-height: 1.1;
  margin-bottom: 1rem;
  letter-spacing: -0.02em;
}

.hero-subtitle {
  font-size: 1.05rem;
  color: var(--text-dim);
  margin-bottom: 1.2rem;
}

.hero-desc {
  font-size: 0.97rem;
  color: var(--text-dim);
  max-width: 520px;
  margin-bottom: 2rem;
  line-height: 1.8;
}

.hero-btns { display: flex; gap: 1rem; flex-wrap: wrap; }

/* Buttons */
.btn {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.75rem 1.75rem;
  border-radius: 6px;
  font-family: var(--font-mono);
  font-size: 0.82rem;
  font-weight: 500;
  letter-spacing: 0.04em;
  cursor: pointer;
  transition: all 0.25s;
}

.btn-primary {
  background: var(--accent);
  color: var(--bg);
  border: 2px solid var(--accent);
}

.btn-primary:hover {
  background: transparent;
  color: var(--accent);
  box-shadow: 0 0 20px rgba(0,212,255,0.3);
}

.btn-outline {
  background: transparent;
  color: var(--text);
  border: 2px solid rgba(255,255,255,0.15);
}

.btn-outline:hover {
  border-color: var(--accent);
  color: var(--accent);
}

.btn-large { padding: 1rem 2.5rem; font-size: 0.9rem; }

/* Hero Photo */
.hero-photo-wrap {
  position: relative;
  width: 300px;
  height: 340px;
  flex-shrink: 0;
}

.blob-bg {
  position: absolute;
  inset: -20px;
  background: radial-gradient(ellipse at center, rgba(124,58,237,0.4), rgba(0,212,255,0.2) 60%, transparent 80%);
  border-radius: 60% 40% 30% 70% / 60% 30% 70% 40%;
  animation: blobAnim 8s ease-in-out infinite;
  z-index: 0;
}

@keyframes blobAnim {
  0%, 100% { border-radius: 60% 40% 30% 70% / 60% 30% 70% 40%; }
  50% { border-radius: 30% 60% 70% 40% / 50% 60% 30% 60%; }
}

.hero-photo {
  position: relative;
  z-index: 1;
  width: 260px;
  height: 300px;
  object-fit: cover;
  object-position: top;
  border-radius: 50% 50% 50% 50% / 60% 60% 40% 40%;
  margin: auto;
  box-shadow: 0 0 40px rgba(0,212,255,0.2);
  border: 2px solid rgba(0,212,255,0.3);
}

.photo-ring {
  position: absolute;
  inset: -12px;
  border-radius: 50%;
  border: 1px dashed rgba(0,212,255,0.2);
  animation: spin 20s linear infinite;
}

@keyframes spin { to { transform: rotate(360deg); } }

/* Scroll hint */
.scroll-hint {
  position: absolute;
  bottom: 2rem; left: 50%;
  transform: translateX(-50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.5rem;
  font-family: var(--font-mono);
  font-size: 0.7rem;
  color: var(--text-dim);
  letter-spacing: 0.1em;
  text-transform: uppercase;
}

.scroll-line {
  width: 1px; height: 50px;
  background: linear-gradient(to bottom, var(--accent), transparent);
  animation: scrollPulse 2s ease-in-out infinite;
}

@keyframes scrollPulse {
  0%, 100% { opacity: 0.3; transform: scaleY(0.8); }
  50% { opacity: 1; transform: scaleY(1); }
}

/* ═══════════════════════════════════════════
   SECTION SHARED
═══════════════════════════════════════════ */
section {
  padding: 6rem 0;
  position: relative;
}

section:nth-child(even) { background: var(--bg2); }

.section-title {
  font-family: var(--font-head);
  font-size: clamp(1.8rem, 4vw, 2.6rem);
  font-weight: 700;
  margin-bottom: 0.5rem;
  letter-spacing: -0.01em;
  position: relative;
  display: inline-block;
}

.section-title::after {
  content: '';
  display: block;
  width: 50px; height: 3px;
  background: var(--accent);
  margin-top: 0.5rem;
  border-radius: 2px;
}

.section-sub {
  color: var(--text-dim);
  margin-bottom: 3rem;
  font-size: 0.95rem;
}

/* ═══════════════════════════════════════════
   ABOUT
═══════════════════════════════════════════ */
.about-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 3rem;
  align-items: start;
  margin-top: 2.5rem;
}

/* Terminal */
.terminal-card {
  background: #0e1420;
  border: 1px solid rgba(0,212,255,0.15);
  border-radius: 10px;
  overflow: hidden;
  box-shadow: var(--glow);
  font-family: var(--font-mono);
  font-size: 0.83rem;
}

.terminal-header {
  background: #171e2e;
  padding: 0.7rem 1rem;
  display: flex;
  align-items: center;
  gap: 0.5rem;
  border-bottom: 1px solid rgba(255,255,255,0.05);
}

.dot {
  width: 12px; height: 12px;
  border-radius: 50%;
}
.dot.red    { background: #ff5f57; }
.dot.yellow { background: #febc2e; }
.dot.green  { background: #28c840; }

.terminal-title {
  margin-left: 0.5rem;
  color: var(--text-dim);
  font-size: 0.75rem;
}

.terminal-body {
  padding: 1.2rem 1.5rem;
  line-height: 1.9;
}

.t-keyword { color: #7dd3fc; }
.t-op      { color: #94a3b8; }
.t-string  { color: #86efac; }
.t-num     { color: #fb923c; }
.t-comment { color: #475569; font-style: italic; }
.t-indent  { padding-left: 1.5rem; }

.t-cursor {
  display: inline-block;
  color: var(--accent);
  animation: blink 1s step-end infinite;
}
@keyframes blink { 50% { opacity: 0; } }

/* About text */
.about-text-block p {
  color: var(--text-dim);
  margin-bottom: 1.2rem;
  line-height: 1.8;
}

.about-text-block strong { color: var(--text); }

.about-stats {
  display: flex;
  gap: 2rem;
  margin-top: 2rem;
}

.stat-item { text-align: center; }

.stat-num {
  display: block;
  font-family: var(--font-head);
  font-size: 2rem;
  font-weight: 800;
  color: var(--accent);
  line-height: 1.1;
}

.stat-label {
  font-family: var(--font-mono);
  font-size: 0.72rem;
  color: var(--text-dim);
  text-transform: uppercase;
  letter-spacing: 0.08em;
}

/* ═══════════════════════════════════════════
   SKILLS
═══════════════════════════════════════════ */
.skills-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.5rem;
  margin-top: 2.5rem;
  margin-bottom: 3rem;
}

.skill-category {
  background: var(--card-bg);
  border: 1px solid var(--border);
  border-radius: 10px;
  padding: 1.5rem;
}

.skill-cat-title {
  font-family: var(--font-head);
  font-size: 0.95rem;
  font-weight: 600;
  margin-bottom: 1rem;
  color: var(--accent);
  display: flex;
  align-items: center;
  gap: 0.5rem;
}

.skill-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
}

.tag {
  padding: 0.3rem 0.75rem;
  border-radius: 20px;
  font-family: var(--font-mono);
  font-size: 0.75rem;
  background: rgba(255,255,255,0.05);
  border: 1px solid rgba(255,255,255,0.08);
  color: var(--text-dim);
  transition: 0.2s;
}

.tag:hover { border-color: var(--accent); color: var(--accent); }

.tag-accent {
  background: rgba(0,212,255,0.06);
  border-color: rgba(0,212,255,0.15);
  color: #7dd3fc;
}

.tag-purple {
  background: rgba(124,58,237,0.08);
  border-color: rgba(124,58,237,0.2);
  color: #c4b5fd;
}

/* Skill bars */
.skill-bars { display: flex; flex-direction: column; gap: 1.2rem; }

.bar-item {}

.bar-label {
  display: flex;
  justify-content: space-between;
  font-family: var(--font-mono);
  font-size: 0.8rem;
  color: var(--text-dim);
  margin-bottom: 0.4rem;
}

.bar-pct { color: var(--accent); }

.bar-track {
  height: 4px;
  background: rgba(255,255,255,0.06);
  border-radius: 4px;
  overflow: hidden;
}

.bar-fill {
  height: 100%;
  width: 0;
  background: linear-gradient(90deg, var(--accent2), var(--accent));
  border-radius: 4px;
  transition: width 1.2s cubic-bezier(0.4, 0, 0.2, 1);
}

/* ═══════════════════════════════════════════
   PROJECTS
═══════════════════════════════════════════ */
.projects-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 1.5rem;
  margin-top: 2.5rem;
}

.project-card {
  background: var(--card-bg);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 1.75rem;
  transition: all 0.3s;
  position: relative;
  overflow: hidden;
}

.project-card::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, rgba(0,212,255,0.04), transparent);
  opacity: 0;
  transition: opacity 0.3s;
}

.project-card:hover {
  border-color: rgba(0,212,255,0.35);
  transform: translateY(-4px);
  box-shadow: 0 12px 40px rgba(0,212,255,0.1);
}

.project-card:hover::before { opacity: 1; }

.project-card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 1rem;
}

.project-icon {
  width: 44px; height: 44px;
  background: rgba(0,212,255,0.1);
  border: 1px solid rgba(0,212,255,0.2);
  border-radius: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--accent);
  font-size: 1.1rem;
}

.project-links a {
  color: var(--text-dim);
  font-size: 1.1rem;
  transition: color 0.2s;
}

.project-links a:hover { color: var(--accent); }

.project-card h3 {
  font-family: var(--font-head);
  font-size: 1.1rem;
  font-weight: 700;
  margin-bottom: 0.2rem;
}

.project-domain {
  font-family: var(--font-mono);
  font-size: 0.72rem;
  color: var(--accent);
  text-transform: uppercase;
  letter-spacing: 0.08em;
  margin-bottom: 0.8rem;
}

.project-desc {
  color: var(--text-dim);
  font-size: 0.88rem;
  line-height: 1.75;
  margin-bottom: 1.2rem;
}

.project-desc strong { color: var(--text); }

.project-stack {
  display: flex;
  flex-wrap: wrap;
  gap: 0.4rem;
}

.project-stack span {
  padding: 0.2rem 0.6rem;
  border-radius: 4px;
  font-family: var(--font-mono);
  font-size: 0.7rem;
  background: rgba(124,58,237,0.12);
  border: 1px solid rgba(124,58,237,0.2);
  color: #c4b5fd;
}

/* ═══════════════════════════════════════════
   EDUCATION
═══════════════════════════════════════════ */
.edu-timeline {
  margin-top: 2.5rem;
  position: relative;
  padding-left: 2rem;
}

.edu-timeline::before {
  content: '';
  position: absolute;
  left: 6px; top: 0; bottom: 0;
  width: 1px;
  background: linear-gradient(to bottom, var(--accent), transparent);
}

.edu-item {
  position: relative;
  margin-bottom: 1.5rem;
}

.edu-dot {
  position: absolute;
  left: -1.7rem;
  top: 1.2rem;
  width: 13px; height: 13px;
  border-radius: 50%;
  background: var(--accent);
  border: 2px solid var(--bg);
  box-shadow: 0 0 10px rgba(0,212,255,0.5);
}

.edu-card {
  background: var(--card-bg);
  border: 1px solid var(--border);
  border-radius: 10px;
  padding: 1.25rem 1.5rem;
  transition: 0.2s;
}

.edu-card:hover {
  border-color: rgba(0,212,255,0.25);
}

.edu-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 1rem;
  flex-wrap: wrap;
}

.edu-card h3 {
  font-family: var(--font-head);
  font-size: 1rem;
  font-weight: 600;
  margin-bottom: 0.2rem;
}

.edu-inst {
  font-size: 0.82rem;
  color: var(--text-dim);
}

.edu-inst i { margin-right: 0.3rem; }

.edu-meta {
  text-align: right;
  flex-shrink: 0;
}

.edu-year {
  display: block;
  font-family: var(--font-mono);
  font-size: 0.75rem;
  color: var(--text-dim);
  margin-bottom: 0.3rem;
}

.edu-grade {
  display: inline-block;
  background: rgba(0,212,255,0.1);
  color: var(--accent);
  border: 1px solid rgba(0,212,255,0.2);
  border-radius: 4px;
  padding: 0.15rem 0.5rem;
  font-family: var(--font-mono);
  font-size: 0.75rem;
  font-weight: 500;
}

.edu-note {
  margin-top: 0.6rem;
  font-size: 0.8rem;
  color: var(--text-dim);
}

/* Achievements */
.achievements-wrap, .extra-wrap {
  margin-top: 4rem;
}

.ach-heading {
  font-family: var(--font-head);
  font-size: 1.3rem;
  font-weight: 700;
  margin-bottom: 1.5rem;
  color: var(--text);
}

.ach-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 1rem;
}

.ach-card {
  background: var(--card-bg);
  border: 1px solid var(--border);
  border-radius: 10px;
  padding: 1.5rem;
  text-align: center;
  transition: 0.3s;
}

.ach-card:hover {
  border-color: rgba(0,212,255,0.3);
  transform: translateY(-3px);
}

.ach-card i {
  font-size: 1.8rem;
  color: var(--accent);
  margin-bottom: 0.8rem;
  display: block;
}

.ach-card h4 {
  font-family: var(--font-head);
  font-size: 0.9rem;
  margin-bottom: 0.5rem;
}

.ach-card p {
  font-size: 0.8rem;
  color: var(--text-dim);
  line-height: 1.6;
}

.ach-card strong { color: var(--accent); }

/* Extracurriculars */
.extra-grid {
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.extra-card {
  background: var(--card-bg);
  border: 1px solid var(--border);
  border-radius: 10px;
  padding: 1.25rem 1.5rem;
  display: flex;
  align-items: flex-start;
  gap: 1rem;
}

.extra-card i {
  font-size: 1.4rem;
  color: var(--accent);
  margin-top: 0.2rem;
  flex-shrink: 0;
}

.extra-card h4 {
  font-family: var(--font-head);
  font-size: 0.95rem;
  font-weight: 600;
  margin-bottom: 0.1rem;
}

.extra-card span {
  font-family: var(--font-mono);
  font-size: 0.72rem;
  color: var(--accent2);
  display: block;
  margin-bottom: 0.3rem;
}

.extra-card p {
  font-size: 0.83rem;
  color: var(--text-dim);
}

/* ═══════════════════════════════════════════
   CONTACT
═══════════════════════════════════════════ */
#contact {
  text-align: center;
  overflow: hidden;
}

.contact-orb {
  position: absolute;
  width: 600px; height: 600px;
  left: 50%; top: 50%;
  transform: translate(-50%, -50%);
  background: radial-gradient(circle, rgba(124,58,237,0.08), transparent 70%);
  border-radius: 50%;
  pointer-events: none;
}

#contact .section-title::after { margin: 0.5rem auto 0; }

#contact .section-sub { margin-top: 0.8rem; }

.contact-inner {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2rem;
  margin-top: 3rem;
}

.contact-info {
  display: flex;
  gap: 2rem;
  flex-wrap: wrap;
  justify-content: center;
}

.contact-link {
  display: flex;
  align-items: center;
  gap: 0.6rem;
  color: var(--text-dim);
  font-family: var(--font-mono);
  font-size: 0.85rem;
  transition: color 0.2s;
  padding: 0.6rem 1.2rem;
  border: 1px solid var(--border);
  border-radius: 6px;
}

.contact-link i { color: var(--accent); font-size: 1rem; }

.contact-link:hover {
  color: var(--accent);
  border-color: rgba(0,212,255,0.3);
}

/* ═══════════════════════════════════════════
   FOOTER
═══════════════════════════════════════════ */
footer {
  background: var(--bg);
  border-top: 1px solid var(--border);
  padding: 2rem 3rem;
}

.footer-inner {
  max-width: 1100px;
  margin: 0 auto;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
  flex-wrap: wrap;
}

.footer-inner p {
  font-family: var(--font-mono);
  font-size: 0.78rem;
  color: var(--text-dim);
}

.footer-socials {
  display: flex;
  gap: 1rem;
}

.footer-socials a {
  color: var(--text-dim);
  font-size: 1rem;
  transition: color 0.2s;
}

.footer-socials a:hover { color: var(--accent); }

/* ═══════════════════════════════════════════
   SCROLL REVEAL
═══════════════════════════════════════════ */
.reveal {
  opacity: 0;
  transform: translateY(30px);
  transition: opacity 0.7s ease, transform 0.7s ease;
}

.reveal.visible {
  opacity: 1;
  transform: translateY(0);
}

/* ═══════════════════════════════════════════
   RESPONSIVE
═══════════════════════════════════════════ */
@media (max-width: 900px) {
  #navbar { padding: 1rem 1.5rem; }

  .nav-links { display: none; }

  .hamburger { display: flex; }

  .mobile-menu.open { display: block; }

  #hero { padding: 6rem 1.5rem 4rem; }

  .hero-content { flex-direction: column-reverse; align-items: center; text-align: center; }

  .hero-photo-wrap { width: 240px; height: 270px; }

  .hero-photo { width: 210px; height: 240px; }

  .hero-btns { justify-content: center; }

  .about-grid { grid-template-columns: 1fr; }

  .skills-grid { grid-template-columns: 1fr; }

  .projects-grid { grid-template-columns: 1fr; }

  .ach-grid { grid-template-columns: repeat(2, 1fr); }

  footer .footer-inner { flex-direction: column; text-align: center; }
}

@media (max-width: 480px) {
  .ach-grid { grid-template-columns: 1fr; }

  .about-stats { gap: 1.2rem; }

  .stat-num { font-size: 1.6rem; }

  .contact-info { flex-direction: column; align-items: stretch; }
}
